experiments/checkpoints/*
!experiments/checkpoints/.gitkeep
*.pt
*.pth

# Logs (ignore contents, keep directory)
experiments/logs/*
!experiments/logs/.gitkeep
runs/
*.log

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Reference (keep structure, ignore cloned repo contents)
reference/*
!reference/.gitignore

# Jupyter
.ipynb_checkpoints/

# Misc
*.tmp
result.json
